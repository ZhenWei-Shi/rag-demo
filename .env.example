# EN: Copy this file to .env and fill in your values.
# ZH: 将此文件复制为 .env 并填入实际配置。

# EN: LLM provider — "openai_compat" for DeepSeek/OpenAI, "ollama" for local Ollama.
# ZH: LLM 提供商 —— "openai_compat" 用于 DeepSeek/OpenAI，"ollama" 用于本地 Ollama。
LLM_PROVIDER=openai_compat

# EN: DeepSeek (or any OpenAI-compatible) API credentials.
# ZH: DeepSeek（或任意 OpenAI 兼容接口）的 API 凭证。
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# EN: Ollama model name (only used when LLM_PROVIDER=ollama).
# ZH: Ollama 模型名称（仅在 LLM_PROVIDER=ollama 时生效）。
OLLAMA_MODEL=llama3.2

# EN: Aliyun OCR credentials (optional). When set, cloud OCR replaces Tesseract for scanned PDFs.
#     Create a RAM user with AliyunOCRFullAccess, generate an AccessKey, and paste below.
# ZH: 阿里云 OCR 凭证（可选）。设置后，云端 OCR 将替代 Tesseract 处理扫描版 PDF。
#     创建具有 AliyunOCRFullAccess 权限的 RAM 用户，生成 AccessKey 后填入下方。
ALIYUN_OCR_AK=your_access_key_id_here
ALIYUN_OCR_SK=your_access_key_secret_here
